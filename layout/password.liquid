<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <title>{{ shop.name }}</title>
    {{ content_for_header }}
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              charcoal: '#050505',
              pearl: '#F5F5F7',
              gold: '#D4AF37',
              muted: '#1A1A1A',
            }
          }
        }
      }
    </script>
  </head>
  <body class="bg-charcoal text-pearl" dir="rtl">
    {{ content_for_layout }}
  </body>
</html>
