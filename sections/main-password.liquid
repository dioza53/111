    <h1 class="text-4xl font-black text-gold">LumiBrace</h1>
    <p>האתר שלנו עתיד להיפתח בקרוב!</p>
    {% form 'storefront_password' %}
      <input type="password" name="password" placeholder="סיסמה" class="text-charcoal px-4 py-2 mt-4 rounded-xl" />
